name: Build macOS arm64

on:
  workflow_dispatch: # Telefondan manuel olarak tetikleyebilmek için

jobs:
  build:
    runs-on: macos-14 # macOS 14 doğrudan Apple Silicon (M1/M4 arm64) üzerinde çalışır

    steps:
      - name: Kodu Çek (Checkout)
        uses: actions/checkout@v4

      # Eğer projen Python, Node.js veya Go gibi ek bağımlılıklar istiyorsa buraya kurulum adımları eklenebilir.
      # Örneğin Swift/Xcode projesiyse doğrudan derlemeye geçebilirsin.

      - name: Projeyi Derle (Build)
        run: |
          # Buraya projene uygun build komutunu yazmalısın. Örneğin:
          # swift build -c release --arch arm64
          # Veya xcodebuild kullanılıyorsa ona uygun komut.
          echo "Derleme komutunu buraya yerleştirin" 

      - name: Çıktıyı (Artifact) Kaydet ve Yayınla
        uses: actions/upload-artifact@v4
        with:
          name: MacCleanerPro-macOS-arm64
          path: |
            path/to/output/MacCleanerPro.app
            path/to/output/MacCleanerPro
            # Derlenen .app veya executable dosyasının repondaki yolunu buraya yazmalısın.
